{
  "version": 2,
  "framework": "nuxtjs",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET,OPTIONS,POST",
        "Access-Control-Allow-Headers": "Origin, X-Requested-With, Content-Type, Accept, Range"
      }
    }
  ]
}
